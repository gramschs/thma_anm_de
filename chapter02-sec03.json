ignal:\")\nprint(f\"  Standardabweichung: {np.std(a_sauber):.4f} m/s^2\")\nprint(f\"  Maximum:            {np.max(a_sauber):.4f} m/s^2\")\n\nprint(\"Verrauschtes Signal:\")\nprint(f\"  Standardabweichung: {np.std(a_verrauscht):.4f} m/s^2\")\nprint(f\"  Maximum:            {np.max(a_verrauscht):.4f} m/s^2\")","key":"lCUBKZUuFH"},{"type":"outputs","id":"HzkiAOuR0rTmil0vLehWR","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Sauberes Signal:\n  Standardabweichung: 1.4400 m/s^2\n  Maximum:            4.8140 m/s^2\nVerrauschtes Signal:\n  Standardabweichung: 1.4877 m/s^2\n  Maximum:            4.8866 m/s^2\n"},"key":"WeKLIjuK7l"}],"key":"AtLnKpDSYh"}],"key":"DSAwEhqDHv"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":198,"column":1},"end":{"line":204,"column":1}},"children":[{"type":"text","value":"Die Standardabweichung des verrauschten Signals ist größer als die des\nsauberen Signals, weil das Rauschen zur Gesamtvarianz beiträgt. Das Maximum\ndes verrauschten Signals kann deutlich vom sauberen Maximalwert abweichen,\nweil ein einzelner Rauschausreißer den Maximalwert verfälschen kann. Das ist\nein wichtiger Grund, in der Messtechnik nie nur einen Maximalwert zu\nbetrachten, sondern immer statistische Kenngrößen wie die\nStandardabweichung.","position":{"start":{"line":198,"column":1},"end":{"line":198,"column":1}},"key":"dTxHeWbmIW"}],"key":"BUahbOF9UK"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Mini-Übung","position":{"start":{"line":206,"column":1},"end":{"line":206,"column":1}},"key":"vrzlHQlsXa"}],"key":"JZcgoOx2KE"},{"type":"paragraph","position":{"start":{"line":208,"column":1},"end":{"line":208,"column":1}},"children":[{"type":"text","value":"Wir untersuchen, wie stark das Rauschen den Mittelwert des Signals verfälscht.","position":{"start":{"line":208,"column":1},"end":{"line":208,"column":1}},"key":"d8xnmtTMsu"}],"key":"Jpr