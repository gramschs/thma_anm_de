p.random.normal(0.0, sigma, size=len(t))\na_verrauscht = a_sauber + rauschen\n\n# Vergleich der Mittelwerte\nmw_sauber    = np.mean(a_sauber)\nmw_verrauscht = np.mean(a_verrauscht)\n\nprint(f\"Mittelwert sauber:     {mw_sauber:.4f} m/s²\")\nprint(f\"Mittelwert verrauscht: {mw_verrauscht:.4f} m/s²\")\nprint(f\"Abweichung:            {abs(mw_verrauscht - mw_sauber):.4f} m/s²\")","position":{"start":{"line":225,"column":1},"end":{"line":250,"column":1}},"key":"cQZgxvRNUG"},{"type":"paragraph","position":{"start":{"line":252,"column":1},"end":{"line":252,"column":1}},"children":[{"type":"text","value":"Ausgabe:","position":{"start":{"line":252,"column":1},"end":{"line":252,"column":1}},"key":"pBUVP0DOog"}],"key":"BP6QsWbSLG"},{"type":"code","lang":"","value":"Mittelwert sauber:     0.0377 m/s²\nMittelwert verrauscht: 0.0151 m/s²\nAbweichung:            0.0226 m/s²","position":{"start":{"line":253,"column":1},"end":{"line":257,"column":1}},"key":"HamN0bBKM3"},{"type":"paragraph","position":{"start":{"line":259,"column":1},"end":{"line":264,"column":1}},"children":[{"type":"text","value":"Die Abweichung der Mittelwerte ist sehr klein, obwohl die Standardabweichung\ndes Rauschens mit 0.5 m/s² deutlich größer ist. Das zeigt eine wichtige\nEigenschaft des Mittelwerts: Normalverteiltes Rauschen mit Erwartungswert\nnull beeinflusst den Mittelwert kaum, weil sich positive und negative\nAusreißer im Schnitt aufheben. Der Mittelwert ist daher ein robustes Maß\ngegen Rauschen, das Maximum dagegen nicht.","position":{"start":{"line":259,"column":1},"end":{"line":259,"column":1}},"key":"muh3fmDBrG"}],"key":"PZAzTluXCS"}],"class":"tip dropdown","key":"Qs9Ssy5Dsy"},{"type":"heading","depth":2,"position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"children":[{"type":"text","value":"Zusammenfassung und Ausblick","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"key":"niYcabYMFz"}],"identifier":"zusammenfassung-und-ausblick","label":"Zusamme