2']\n\nfig, ax = plt.subplots(nrows=2, ncols=2, figsize=(12, 8))\n\nfor i, (sig, tit, farbe) in enumerate(zip(signale, titel, farben)):\n    zeile  = i // 2\n    spalte = i  % 2\n    ax[zeile, spalte].plot(t, sig, color=farbe, linewidth=1.5)\n    ax[zeile, spalte].set_title(tit)\n    ax[zeile, spalte].set_xlabel('Zeit in s')\n    ax[zeile, spalte].set_ylabel('Beschleunigung in m/s²')\n    ax[zeile, spalte].grid(True)\n\nplt.tight_layout()\nplt.show()","key":"rLShuvgiAK"},{"type":"outputs","id":"iDmiF1ahaCUvHEbM6n7FB","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x800 with 4 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"19c0cc93d875b83b6096e30dde3aaa23","path":"/thma_anm_de/build/19c0cc93d875b83b6096e30dde3aaa23.png"}}},"key":"gnNezkO5cj"}],"key":"q6T6NJwgUE"}],"key":"XTU7ZqlQRG"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":176,"column":1},"end":{"line":178,"column":1}},"children":[{"type":"text","value":"Die Kombination aus ","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"UuRuSIew9u"},{"type":"inlineCode","value":"enumerate()","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"K2dUoUDaSt"},{"type":"text","value":" und ","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"TikUruAUVE"},{"type":"inlineCode","value":"zip()","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"HNyCvpLevw"},{"type":"text","value":" erlaubt es, gleichzeitig über\nSignal, Titel und Farbe zu iterieren und den laufenden Index ","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"o8VdHYsDHF"},{"type":"inlineCode","value":"i","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"SIn1HNEzlX"},{"type":"text","value":" zu nutzen.\nMit ","positio